#!/bin/sh
node scripts/build-personas.js --check

# Run ruff on staged orchestrator Python files
STAGED_PY=$(git diff --cached --name-only | grep '^orchestrator/src/.*\.py$')
if [ -n "$STAGED_PY" ]; then
  # Resolve ruff: venv (Unix/Windows layouts), .exe variant, then PATH
  RUFF=""
  if [ -f "orchestrator/.venv/bin/ruff" ]; then
    RUFF="orchestrator/.venv/bin/ruff"
  elif [ -f "orchestrator/.venv/Scripts/ruff.exe" ]; then
    RUFF="orchestrator/.venv/Scripts/ruff.exe"
  elif [ -f "orchestrator/.venv/Scripts/ruff" ]; then
    RUFF="orchestrator/.venv/Scripts/ruff"
  elif command -v ruff > /dev/null 2>&1; then
    RUFF="ruff"
  fi

  if [ -z "$RUFF" ]; then
    echo "WARNING: ruff not found — skipping Python lint check."
    echo "  Install it with: pip install ruff  (inside orchestrator/.venv)"
  else
    echo "Running ruff on staged orchestrator files..."
    "$RUFF" check orchestrator/src/ || exit 1
  fi
fi

# Warn if a sub-project changelog changed without the root changelog
STAGED=$(git diff --cached --name-only)
SUB_CHANGED=0
ROOT_CHANGED=0

echo "$STAGED" | grep -qE '^(mcp-server|personas|orchestrator)/changelog\.md$' && SUB_CHANGED=1
echo "$STAGED" | grep -q '^changelog\.md$' && ROOT_CHANGED=1

if [ "$SUB_CHANGED" -eq 1 ] && [ "$ROOT_CHANGED" -eq 0 ]; then
  echo ""
  echo "WARNING: A sub-project changelog was updated but the root changelog.md was not."
  echo "  Consider summarizing the changes in changelog.md before committing."
  echo ""
fi
