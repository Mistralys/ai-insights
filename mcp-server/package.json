{
  "name": "project-ledger-mcp",
  "version": "2.0.2",
  "type": "module",
  "description": "MCP server for Project Ledger workflow coordination",
  "main": "dist/index.js",
  "scripts": {
    "sync-version": "node scripts/sync-version.js",
    "move-unknown-project": "node scripts/move-unknown-project.js",
    "rename-repository": "node scripts/rename-repository.js",
    "predev": "npm run sync-version",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "pretest": "node ../scripts/build-personas.js && node ../scripts/build-personas.js --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:roles": "node ../scripts/check-known-roles.js",
    "gui": "tsx gui/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "proper-lockfile": "^4.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/proper-lockfile": "^4.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^29.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
