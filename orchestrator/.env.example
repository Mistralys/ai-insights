# === LLM Provider API Keys ===
# Model selection is driven by persona metadata (personas/ledger/src/meta/).
# Each stage's model slug is read from `model_slug` / `default_model_slug`
# fields in the YAML source files. No MODEL_NAME env var is needed.

# Anthropic (pip install -e ".[anthropic]")
ANTHROPIC_API_KEY=sk-ant-...

# Google AI Studio (pip install -e ".[google]")
# GOOGLE_API_KEY=AIza...

# === General settings ===
MAX_ITERATIONS=100
# Directory for LangGraph SQLite checkpoint files (used by --resume).
# To use --resume, install the checkpoint extra first:
#   pip install -e '.[checkpoint]'
CHECKPOINT_DIR=./checkpoints
LOG_LEVEL=INFO
# Seconds of console silence before emitting a heartbeat (0 = disabled).
HEARTBEAT_INTERVAL_S=120
# Capture full agent dialogue exchanges (enabled by default).
# Set to false, 0, or no to disable.
CAPTURE_DIALOGUES=true
